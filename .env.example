# ── AI Kalitlari ──────────────────────────────────────────────────────────────
# Gemini AI (tavsiya etiladi - rasm tahlili va chat uchun)
# https://aistudio.google.com/app/apikey dan oling
REACT_APP_GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude (fallback)
# https://console.anthropic.com/ dan oling
REACT_APP_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (ixtiyoriy, eng yuqori ustuvorlik)
REACT_APP_OPENAI_API_KEY=your_openai_api_key_here

# ── Backend Server ────────────────────────────────────────────────────────────
PORT=5000
FRONTEND_ORIGIN=http://localhost:3000
REACT_APP_TELEGRAM_SERVER_URL=http://localhost:5000

# ── Telegram Bot (ixtiyoriy) ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
